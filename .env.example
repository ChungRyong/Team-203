# ==============================================================================
# Team-203 로컬 멀티 에이전트 가상 스튜디오 - 환경 변수 설정 템플릿 (.env.example)
# ==============================================================================
# 본 파일을 복사하여 '.env' 파일로 이름을 변경한 뒤 로컬 환경에 맞춰 변경하십시오.

# 1. FastAPI 백엔드 채팅 엔진 포트 번호
TEAM203_PORT=8000

# 2. 로컬 Ollama API 추론 엔진 주소
OLLAMA_API_URL=http://localhost:11434

# 3. 대표님(박청룡) 디스코드 가상 오피스 채널용 웹훅 주소 (비상 로그/보고용)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
